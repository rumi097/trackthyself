datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STUDENT
}

model User {
  id             String          @id @default(cuid())
  identifier     String          @unique
  name           String
  passwordHash   String
  role           Role            @default(STUDENT)
  createdAt      DateTime        @default(now())
  profile        StudentProfile?
  tasks          Task[]
  dailyLogs      DailyLog[]
  exams          Exam[]
  focusSessions  FocusSession[]
  badges         Badge[]
}

model StudentProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  targetUniversity   String?
  currentStreak      Int      @default(0)
  longestStreak      Int      @default(0)
  totalFocusMinutes  Int      @default(0)
}

model Subject {
  id         String    @id @default(cuid())
  name       String
  isDefault  Boolean   @default(false)
  chapters   Chapter[]
  exams      Exam[]
}

model Chapter {
  id         String   @id @default(cuid())
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  name       String
  isDefault  Boolean  @default(false)
  order      Int      @default(0)
  tasks      Task[]
}

enum TaskType {
  WEEKLY_RECURRING
  SINGLE_DAY
}

model Task {
  id            String         @id @default(cuid())
  studentId     String
  student       User           @relation(fields: [studentId], references: [id])
  title         String
  chapterId     String?
  chapter       Chapter?       @relation(fields: [chapterId], references: [id])
  linkKey       String?
  type          TaskType
  dayOfWeek     Int?           
  date          DateTime?
  startTime     String         
  endTime       String         
  completionPercent Float      @default(0)
  isCompleted   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  focusSessions FocusSession[] 
}

model DailyLog {
  id                    String   @id @default(cuid())
  studentId             String
  student               User     @relation(fields: [studentId], references: [id])
  date                  DateTime
  totalTasks            Int
  completedTasks        Int
  completionPercentage  Float
}

model Exam {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation(fields: [studentId], references: [id])
  title         String
  date          DateTime
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  totalMarks    Float
  obtainedMarks Float
  notes         String?
}

model FocusSession {
  id              String   @id @default(cuid())
  studentId       String
  student         User     @relation(fields: [studentId], references: [id])
  taskId          String?
  task            Task?    @relation(fields: [taskId], references: [id])
  durationMinutes Int
  completedAt     DateTime @default(now())
}

model Badge {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation(fields: [studentId], references: [id])
  badgeType   String
  awardedAt   DateTime @default(now())
}
